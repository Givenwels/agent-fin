# 复制本文件为 .env，或运行：
#   python main.py --setup-api
#
# 默认接入 Codex/OpenAI API（OpenAI SDK）。
# 密钥只放本地 .env；不要提交真实 key。

FIN_API_PROVIDER=codex
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-5.1

# 可选：如果使用 OpenAI-compatible 网关才填写；直连 OpenAI 官方时留空/删除即可。
# OPENAI_BASE_URL=https://api.openai.com/v1

# 兼容旧 Anthropic / Anthropic-compatible endpoint；默认不用。
# FIN_API_PROVIDER=anthropic
# ANTHROPIC_AUTH_TOKEN=sk-xxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
# ANTHROPIC_BASE_URL=https://example.com
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# 可选：知识库根目录，多个根用 ; 或 , 分隔。
# FIN_KB_DIR=F:\笔记obsinlin\随便写\学习\财经

# 可选：工具调用护栏。
# FIN_TOOL_TIMEOUT_SECONDS=30
# FIN_TOOL_OUTPUT_CHARS=6000
